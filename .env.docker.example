# Mindspace — Docker Compose environment template
# Copy this file to ".env" (same directory as docker-compose.yml) and fill in real values.
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Database ---
DB_NAME=mental_health_tracker
DB_USER=postgres
DB_PASSWORD=change_me_strong_db_password

# --- Application mode ---
NODE_ENV=development

# --- Security (REQUIRED — generate strong unique values) ---
JWT_SECRET=change_me_generate_64_char_hex
JWT_EXPIRE=4h
ENCRYPTION_KEY=change_me_generate_32_char_min
ADMIN_PASSWORD=change_me_min_12_chars

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS (frontend origin) ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend build-time API base URL ---
VITE_API_BASE_URL=http://localhost:5000/api

# --- Luna LLM provider (optional, default off) ---
# See backend/.env.example for the full set of LUNA_LLM_* knobs.
LUNA_PROVIDER=rule_based
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Web Push (optional, default off) ---
# Generate once: node backend/scripts/generate-vapid.js
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
