# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.production

# Personal files
my_CV/

# Visa-application internals (NEVER commit — see HANDOVER_PENDING_FEATURES.md)
Mental_Health_Tracker_Technical_Evidence_OC1_OC3.md

# All markdown documentation kept LOCAL only — only the root README.md is public.
# Catches every .md at any depth, then re-includes the root README so the
# public repo still has its landing page. Add new internal docs without
# worrying about accidental commit.
*.md
!README.md
# Explicit entries kept below for documentation of WHY each one is excluded;
# all also covered by the *.md wildcard above.
HANDOVER_DOCUMENT.md
PROJECT_SUMMARY.md

# Jest coverage reports
coverage/
backend/coverage/
frontend/coverage/

# Binary documents (keep .md docs, exclude .docx)
*.docx

# Temp/junk files
nul

# Local-only one-shot scripts (e.g. seed-rich-demo.local.js).
# Convention: *.local.js anywhere is gitignored, so throw-away scripts
# that connect to prod-ish resources never get committed by accident.
*.local.js
tmpclaude-*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Build output
dist/
build/
.cache/

# Database files
*.db
*.sqlite
.local-backups/
backend/.local-backups/

# Python (Chronos sidecar — ADR-0012)
__pycache__/
*.pyc
