# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mental_health_tracker
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here

# Database SSL Configuration (for production)
# DB_SSL=true
# DB_SSL_CA=/path/to/ca-certificate.crt
# DB_SSL_REJECT_UNAUTHORIZED=true

# Security - IMPORTANT: Generate strong, unique values for production!
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_random_64_char_string
JWT_EXPIRE=4h
ENCRYPTION_KEY=CHANGE_ME_generate_random_32_char_string

# Admin JWT Secret (optional — auto-derived from JWT_SECRET if omitted, but a separate value is recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ADMIN_JWT_SECRET=CHANGE_ME_generate_separate_admin_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Crisis Resources API (Optional)
CRISIS_API_KEY=your_api_key_here

# Admin Panel (for /admin access)
# IMPORTANT: Set a strong password (minimum 12 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_PASSWORD=CHANGE_ME_set_secure_admin_password

# === Luna LLM provider (optional) ===
# Two-tier consent for LLM-backed Luna:
#   (a) Deployment-level: set LUNA_PROVIDER=anthropic to enable the LLM provider
#       at all (default 'rule_based' keeps everything offline + free).
#   (b) Per-user: each user must additionally set llm_opted_in=true on their
#       luna_profile before they personally receive LLM responses.
# If LUNA_PROVIDER=anthropic but ANTHROPIC_API_KEY is missing / the SDK isn't
# installed, the factory falls back to rule_based with a logged warning —
# chat never breaks because of LLM config.
LUNA_PROVIDER=rule_based
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx
# LUNA_LLM_MODEL=claude-haiku-4-5-20251001
# LUNA_LLM_MAX_TOKENS=600
# LUNA_LLM_TIMEOUT_MS=15000
# LUNA_LLM_DAILY_LIMIT=30                # per-user calls per day
# LUNA_LLM_MONTHLY_TOKEN_CAP=5000000     # hard ceiling, ~$1.50/mo on Haiku 4.5
# LUNA_LLM_CIRCUIT_THRESHOLD=5           # consecutive failures before circuit opens
# LUNA_LLM_CIRCUIT_COOLDOWN_MS=60000

# === Web Push notifications (optional) ===
# Web Push delivers OS-level notifications to OFFLINE users (Socket.io still
# covers online users). Generate a key pair ONCE per deployment:
#   node backend/scripts/generate-vapid.js
# Then paste the printed values here. Never commit them.
# If VAPID_PUBLIC_KEY or VAPID_PRIVATE_KEY is missing, Web Push silently
# no-ops with a logged warning — Socket.io still works.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
