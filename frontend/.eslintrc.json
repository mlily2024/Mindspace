{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "extends": "eslint:recommended",
  "plugins": ["unused-imports", "react"],
  "settings": {
    "react": { "version": "detect" }
  },
  "rules": {
    "no-unused-vars": "off",
    "unused-imports/no-unused-imports": "warn",
    "unused-imports/no-unused-vars": ["warn", { "args": "after-used", "argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "caughtErrors": "none" }],
    "react/jsx-uses-vars": "error",
    "react/jsx-uses-react": "error",
    "no-console": "off",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-undef": "off",
    "no-prototype-builtins": "off",
    "no-constant-condition": "off",
    "no-useless-escape": "warn",
    "no-case-declarations": "warn",
    "no-async-promise-executor": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "coverage/",
    "*.config.js",
    "scripts/"
  ]
}
